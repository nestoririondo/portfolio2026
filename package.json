{
  "name": "portfolio2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "node --env-file-if-exists=.env.local --watch server/index.js",
